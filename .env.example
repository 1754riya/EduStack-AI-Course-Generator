# ─── Clerk Authentication ────────────────────────────────────────────────────
# Create a free account at https://clerk.com
# Dashboard → API Keys → Copy "Publishable Key" and "Secret Key"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect paths — keep as-is unless you rename the route segments
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Create a free database at https://neon.tech
# Dashboard → Your Project → Connection Details → Connection String
# After setting this value locally, run: npm run db:push
NEXT_PUBLIC_DB_CONNECTION_STRING=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Google Cloud Console → Enable "YouTube Data API v3" → Credentials → Create API Key
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Firebase Storage ────────────────────────────────────────────────────────
# Firebase Console → Project Settings → General → Your Apps → Web App → SDK config → apiKey
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Application Host ────────────────────────────────────────────────────────
# Used to build shareable course URLs (WhatsApp, Email, LinkedIn share buttons)
# Local development:
NEXT_PUBLIC_HOST_NAME=http://localhost:3000
# Production (set this in Vercel Environment Variables):
# NEXT_PUBLIC_HOST_NAME=https://your-project.vercel.app
